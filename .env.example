# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and should never be committed.

# football-data.org API key — get one free at https://www.football-data.org/client/register
FOOTBALL_API_KEY=your_key_here

# Base URL for the football-data.org v4 API — do not change
FOOTBALL_API_BASE=https://api.football-data.org/v4

# Competition ID for the 2026 FIFA World Cup — do not change
WORLD_CUP_ID=2000
